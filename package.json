{
  "name": "rest-client-for-springboot",
  "displayName": "SpringBoot HTTP Helper",
  "description": "Generate .http files from SpringBoot Controller mappings, with optional AI-generated test parameters.",
  "version": "0.1.0",
  "icon": "icon.png",
  "publisher": "tangtang-wsj",
  "engines": {
    "vscode": "^1.112.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:springHttpGenerator.createHttpFromMapping"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "springHttpGenerator.createHttpFromMapping",
        "title": "SpringBoot: 生成 Controller HTTP 请求"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "springHttpGenerator.createHttpFromMapping",
          "when": "editorTextFocus && editorLangId == java",
          "group": "navigation@10"
        }
      ]
    },
    "configuration": {
      "title": "SpringBoot HTTP Helper",
      "properties": {
        "springHttpGenerator": {
          "type": "object",
          "default": {
            "baseUrl": "http://localhost:8080",
            "tokenVarName": "Authorization",
            "tokenValue": "",
            "aiEndpoint": "https://api.openai.com/v1/responses",
            "aiApiKey": "",
            "aiModel": "gpt-5.1-codex-max",
            "aiContextAgentPrompt": "你是代码检索智能体，采用 ReAct（Reason + Act）工作流。按 Controller -> Service -> Mapper -> SQL 顺序定位上下文，只输出结构化 JSON，最终仅返回 Service 与 SQL 的有效证据，不返回 Mapper 内容本体。优先结合方法体调用、字段注入与构造注入推断 Service。",
            "sqlSearchGlobs": [
              "**/src/main/resources/sql/**/*.{md,sql,xml}",
              "**/src/main/resources/**/*Mapper.xml",
              "**/*.{md,sql,xml}"
            ],
            "testDataFile": "",
            "aiSystemPrompt": "你是接口测试参数生成助手。仅输出 JSON 对象，且仅保留关键字段，禁止输出 aid 和 修改时间。"
          },
          "description": "统一配置对象（请在 settings.json 中配置 springHttpGenerator，内部使用扁平字段）",
          "properties": {
            "baseUrl": {
              "type": "string",
              "description": "生成 .http 请求时默认使用的服务地址"
            },
            "tokenVarName": {
              "type": "string",
              "description": "认证请求头 key（如 Authorization、x-token）"
            },
            "tokenValue": {
              "type": "string",
              "description": "认证请求头对应的值，会写入 .http 文件变量"
            },
            "aiEndpoint": {
              "type": "string",
              "description": "OpenAI Responses 接口地址"
            },
            "aiApiKey": {
              "type": "string",
              "description": "OpenAI API Key（为空时默认不使用 AI 生成）"
            },
            "aiModel": {
              "type": "string",
              "description": "AI 模型名称"
            },
            "aiContextAgentPrompt": {
              "type": "string",
              "description": "上下文检索智能体提示词（ReAct）"
            },
            "sqlSearchGlobs": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "SQL 资源查找 glob 列表，按顺序匹配"
            },
            "testDataFile": {
              "type": "string",
              "description": "测试数据池文件路径（绝对路径或相对项目根目录）"
            },
            "aiSystemPrompt": {
              "type": "string",
              "description": "AI 系统提示词"
            }
          },
          "additionalProperties": true
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.112.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
